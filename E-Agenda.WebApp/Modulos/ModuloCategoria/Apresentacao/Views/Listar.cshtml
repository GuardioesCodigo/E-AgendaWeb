@using E_Agenda.WebApp.Modulos.ModuloCategoria.Apresentacao
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Categorias";
}
@model List<ListarCategoriasViewModel>

<a class="btn btn-outline-primary rounded-pill px-4 mb-3" asp-action="Cadastrar">Cadastrar Novo</a>

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
        @mensagemErro
    </div>
}

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Nenhuma categoria cadastrada.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2">
        @foreach (ListarCategoriasViewModel c in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <h5 class="card-title mb-0">@c.Titulo</h5>
                            <span class="badge text-bg-primary rounded-pill">
                                @c.Id.ToString().Substring(0, 8)
                            </span>
                        </div>

                        @* <dl class="row g-2 mb-4">
                            <dt class="col-5 text-secondary fw-semibold">Despesas</dt>
                            <dd class="col-7 mb-0">
                                <span class="badge rounded-pill px-2 py-1 fw-semibold"
                                      style="background:#ede9fe;color:#6d28d9;font-size:.75rem;">
                                    @c.QuantidadeDespesas despesa(s)
                                </span>
                            </dd>
                        </dl> *@

                        <div class="d-flex flex-wrap gap-2 mt-auto justify-content-end">
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3"
                               asp-action="Despesas" asp-route-id="@c.Id">Ver Despesas</a>
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3"
                               asp-action="Editar" asp-route-id="@c.Id">Editar</a>
                            <a class="btn btn-outline-danger btn-sm rounded-pill px-3"
                               asp-action="Excluir" asp-route-id="@c.Id">Excluir</a>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
}
