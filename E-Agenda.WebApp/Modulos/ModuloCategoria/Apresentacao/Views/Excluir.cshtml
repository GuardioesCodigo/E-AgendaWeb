@using E_Agenda.WebApp.Modulos.ModuloCategoria.Apresentacao
@{
    Layout = "_Layout";
}
@model ExcluirCategoriasViewModel

<a asp-action="Listar" class="btn btn-outline-secondary rounded-pill px-4 mb-4">
    <i class="bi bi-arrow-left me-1"></i> Voltar
</a>

<div class="container d-flex justify-content-center">
    <div class="card border-0 shadow-sm rounded-4" style="max-width: 620px; width:100%;">
        <div class="card-body p-4">

            <div class="alert alert-danger border-start border-danger border-4 rounded-3 mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                Esta ação é permanente e não poderá ser desfeita.
            </div>

            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                <h5 class="card-title mb-0 fw-bold text-dark">@Model.Titulo</h5>
                <span class="badge text-bg-primary rounded-pill">
                    @Model.Id.ToString().Substring(startIndex: 0, length: 8)
                </span>
            </div>

            <dl class="row g-2 mb-0">
                <dt class="col-5 text-secondary fw-semibold">Despesas</dt>
                <dd class="col-7 mb-0">
                    <span class="badge rounded-pill px-2 py-1 fw-semibold"
                          style="background:#ede9fe;color:#6d28d9;font-size:.75rem;">
                        @Model.QuantidadeDespesasVinculadas despesa(s)
                    </span>
                </dd>
            </dl>
        </div>

        <form asp-action="Excluir" method="post">
            <input asp-for="Id" type="hidden" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger rounded-pill px-4 fw-semibold flex-fill">
                    <i class="bi bi-trash me-1"></i> Confirmar Exclusão
                </button>
                <a asp-action="Listar" class="btn btn-outline-secondary rounded-pill px-4 fw-semibold">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>
