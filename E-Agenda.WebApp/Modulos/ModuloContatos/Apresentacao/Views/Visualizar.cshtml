@using E_Agenda.WebApp.Modulos.ModuloContatos.Apresentacao
@{
    Layout = "_Layout";
}
@model VisualizarContatoViewModel

<a class="btn btn-outline-secondary rounded-pill px-4 mb-4" asp-action="Listar">
    <i class="bi bi-arrow-left me-1"></i> Voltar
</a>

<h2 class="mb-4"><i class="bi bi-person-badge"></i> @Model.Nome</h2>

<div class="card border-0 shadow-sm rounded-4" style="max-width: 640px;">
    <div class="card-body p-4">
        <h5 class="card-title text-primary mb-3">Informações de Contato</h5>
        
        <dl class="row g-2 mb-0">
            <dt class="col-5 text-secondary fw-semibold">Email</dt>
            <dd class="col-7 mb-2">@Model.Email</dd>

            <dt class="col-5 text-secondary fw-semibold">Telefone</dt>
            <dd class="col-7 mb-2">@Model.Telefone</dd>

            <dt class="col-5 text-secondary fw-semibold">Cargo</dt>
            <dd class="col-7 mb-2">@(string.IsNullOrWhiteSpace(Model.Cargo) ? "-" : Model.Cargo)</dd>

            <dt class="col-5 text-secondary fw-semibold">Empresa</dt>
            <dd class="col-7 mb-0">@(string.IsNullOrWhiteSpace(Model.Empresa) ? "-" : Model.Empresa)</dd>
        </dl>
    </div>
    <div class="card-footer bg-white border-0 p-4 pt-0">
        <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-outline-primary rounded-pill px-4">
            <i class="bi bi-pencil me-1"></i> Editar Contato
        </a>
    </div>
</div>