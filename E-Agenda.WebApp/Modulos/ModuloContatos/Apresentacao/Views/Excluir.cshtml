@using E_Agenda.WebApp.Modulos.ModuloContatos.Apresentacao
@{
    Layout = "_Layout";
}
@model ExcluirContatosViewModel

<div style="max-width:640px;">

    <a asp-action="Listar" class="btn btn-outline-secondary rounded-pill px-4 mb-4">
        <i class="bi bi-arrow-left me-1"></i> Voltar
    </a>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h4 class="card-title fw-bold text-danger mb-4">Excluir Contato</h4>
            
            <p class="text-secondary mb-4">
                Tem certeza que deseja excluir o contato <strong>@Model.Nome</strong>? 
                Esta ação é irreversível.
            </p>

            <div class="bg-light p-3 rounded-3 mb-4">
                <p class="mb-1"><strong>E-mail:</strong> @Model.Email</p>
                <p class="mb-0"><strong>Telefone:</strong> @Model.Telefone</p>
            </div>

            <form asp-action="Excluir" method="post">
                @* O ID é essencial para saber qual registro remover *@
                <input asp-for="Id" type="hidden" />

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger rounded-pill px-4 fw-semibold flex-fill">
                        <i class="bi bi-trash3 me-1"></i> Confirmar Exclusão
                    </button>
                    <a asp-action="Listar" class="btn btn-outline-secondary rounded-pill px-4 fw-semibold">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>