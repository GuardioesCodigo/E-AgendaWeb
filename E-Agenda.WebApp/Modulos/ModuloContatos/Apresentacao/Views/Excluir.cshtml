@using E_Agenda.WebApp.Modulos.ModuloContatos.Apresentacao
@{
    Layout = "_Layout";
}
@model ExcluirContatosViewModel

<div style="max-width:640px;">

    <a asp-action="Listar" class="btn btn-outline-secondary rounded-pill px-4 mb-4">
        <i class="bi bi-arrow-left me-1"></i> Voltar
    </a>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4 text-center">
            
            <div class="mb-4 text-danger">
                <i class="bi bi-exclamation-triangle" style="font-size: 3rem;"></i>
            </div>

            <h4 class="card-title fw-bold text-secondary mb-3">Confirmar Exclusão</h4>
            <p class="text-muted mb-4">
                Tem certeza de que deseja excluir o contato <strong>@Model.Nome</strong>?<br>
                Esta ação não poderá ser desfeita.
            </p>

            <form asp-action="Excluir" method="post">
                <input type="hidden" asp-for="Id" />
                
                <div class="d-flex gap-2 justify-content-center">
                    <button type="submit" class="btn btn-danger rounded-pill px-4 fw-semibold">
                        <i class="bi bi-trash-fill me-1"></i> Sim, excluir
                    </button>
                    <a asp-action="Listar" class="btn btn-outline-secondary rounded-pill px-4 fw-semibold">
                        Cancelar
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>