@using E_Agenda.WebApp.Modulos.ModuloContatos.Apresentacao
@{
    Layout = "_Layout";
}
@model CadastrarContatosViewModel

<div style="max-width:640px;">

    <a asp-action="Listar" class="btn btn-outline-secondary rounded-pill px-4 mb-4">
        <i class="bi bi-arrow-left me-1"></i> Voltar
    </a>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h4 class="card-title fw-bold text-secondary mb-4">Novo Contato</h4>
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <form asp-action="Cadastrar" method="post">
                <div class="mb-3">
                    <label asp-for="Nome" class="form-label fw-semibold text-secondary">Nome</label>
                    <input asp-for="Nome" class="form-control rounded-3" placeholder="Nome completo" />
                    <span asp-validation-for="Nome" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label fw-semibold text-secondary">E-mail</label>
                        <input asp-for="Email" class="form-control rounded-3" placeholder="email@exemplo.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Telefone" class="form-label fw-semibold text-secondary">Telefone</label>
                        <input asp-for="Telefone" id="telefone" class="form-control rounded-3" placeholder="(00) 00000-0000" />
                        <span asp-validation-for="Telefone" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label asp-for="Cargo" class="form-label fw-semibold text-secondary">Cargo</label>
                        <input asp-for="Cargo" class="form-control rounded-3" placeholder="Ex: Desenvolvedor" />
                    </div>
                    <div class="col-md-6 mb-4">
                        <label asp-for="Empresa" class="form-label fw-semibold text-secondary">Empresa</label>
                        <input asp-for="Empresa" class="form-control rounded-3" placeholder="Ex: Tech Corp" />
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold text-secondary">Associar Compromissos</label>
                    <div class="border rounded-3 p-3 bg-light" style="max-height: 200px; overflow-y: auto;">
                        @for (int i = 0; i < Model.Compromissos.Count; i++)
                        {
                            <div class="form-check">
                                <input type="hidden" asp-for="Compromissos[i].Id" />
                                <input type="checkbox" asp-for="Compromissos[i].Marcado" class="form-check-input" />
                                <label class="form-check-label">@Model.Compromissos[i].Assunto</label>
                            </div>
                        }
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-semibold flex-fill">
                        <i class="bi bi-floppy me-1"></i> Cadastrar Contato
                    </button>
                    <a asp-action="Listar" class="btn btn-outline-secondary rounded-pill px-4 fw-semibold">
                        Cancelar
                    </a>
                </div>

            </form>

           @section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>
    <script>
        $(document).ready(function(){
            // Certifique-se de que o seletor busca pelo name ou adicione a classe
            $('input[name="Telefone"]').mask('(00) 00000-0000');
        });
    </script>
}
        </div>
    </div>
</div>