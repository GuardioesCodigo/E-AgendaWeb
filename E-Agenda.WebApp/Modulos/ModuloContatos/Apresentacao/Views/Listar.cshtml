@model IEnumerable<E_Agenda.WebApp.Modulos.ModuloContatos.Apresentacao.ListarContatosViewModel>

@{
    ViewData["Title"] = "Contatos";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Meus Contatos</h2>
    <a asp-action="Cadastrar" class="btn btn-primary">Novo Contato</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Nenhum contato encontrado.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var contato in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    @* Adicionamos position-relative aqui para servir de base para o ID *@
                    <div class="card-body position-relative">
                        
                        @* ID posicionado no canto superior direito *@
                        <div class="position-absolute top-0 end-0 p-2">
                            <span class="badge bg-secondary" style="font-size: 0.7rem; opacity: 0.8;">
                                ID: @contato.Id.ToString().Substring(0, 8)
                            </span>
                        </div>

                        <h5 class="card-title">@contato.Nome</h5>
                        
                        <p class="card-text mt-3">
                            <strong>Email:</strong> @contato.Email <br />
                            <strong>Telefone:</strong> @contato.Telefone <br />

                            @if (!string.IsNullOrWhiteSpace(contato.Cargo))
                            {
                                <span><strong>Cargo:</strong> @contato.Cargo</span> <br />
                            }

                            @if (!string.IsNullOrWhiteSpace(contato.Empresa))
                            {
                                <span><strong>Empresa:</strong> @contato.Empresa</span>
                            }
                        </p>
                    </div>
                    
                    <div class="card-footer bg-transparent border-top-0">
                        <a asp-action="Editar" asp-route-id="@contato.Id" class="btn btn-sm btn-outline-warning">Editar</a>
                        <a asp-action="Excluir" asp-route-id="@contato.Id" class="btn btn-sm btn-outline-danger">Excluir</a>
                    </div>
                </div>
            </div>
        }
    </div>
}