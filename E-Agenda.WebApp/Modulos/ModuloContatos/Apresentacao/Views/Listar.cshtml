@using E_Agenda.WebApp.Modulos.ModuloContatos.Apresentacao
@{
    Layout = "_Layout";
}
@model IEnumerable<ListarContatosViewModel>


    
    <a class="btn btn-primary rounded-pill px-4 mb-3" asp-action="Cadastrar">
        <i class="bi bi-plus-lg me-1"></i> Novo Contato
    </a>

@if (!Model.Any())
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Nenhum contato cadastrado até o momento.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2">
        @foreach (var c in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">

                        @* Cabeçalho do Card *@
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <h5 class="card-title mb-0 text-primary">@c.Nome</h5>
                            <span class="badge text-bg-primary rounded-pill">
                                @c.Id.ToString().Substring(0, 8)
                            </span>
                        </div>

                        @* Detalhes *@
                        <dl class="row g-2 mb-4">
                            <dt class="col-5 text-secondary fw-semibold">Email</dt>
                            <dd class="col-7 mb-0 text-truncate" title="@c.Email">@c.Email</dd>

                            <dt class="col-5 text-secondary fw-semibold">Telefone</dt>
                            <dd class="col-7 mb-0">@c.Telefone</dd>

                            @if (!string.IsNullOrWhiteSpace(c.Cargo))
                            {
                                <dt class="col-5 text-secondary fw-semibold">Cargo</dt>
                                <dd class="col-7 mb-0">@c.Cargo</dd>
                            }

                            @if (!string.IsNullOrWhiteSpace(c.Empresa))
                            {
                                <dt class="col-5 text-secondary fw-semibold">Empresa</dt>
                                <dd class="col-7 mb-0">@c.Empresa</dd>
                            }
                        </dl>

                        @* Botões de Ação *@
                        <div class="d-flex flex-wrap gap-2 mt-auto justify-content-end">
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3"
                               asp-action="Visualizar" asp-route-id="@c.Id">
                                Ver Detalhes
                            </a>
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3"
                               asp-action="Editar" asp-route-id="@c.Id">Editar</a>
                            <a class="btn btn-outline-danger btn-sm rounded-pill px-3"
                               asp-action="Excluir" asp-route-id="@c.Id">Excluir</a>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
}