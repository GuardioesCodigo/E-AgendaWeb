@using E_Agenda.WebApp.Modulos.ModuloTarefa.Apresentacao
@using E_Agenda.WebApp.Modulos.ModuloTarefa.Dominio
@using E_Agenda.WebApp.Modulos.ModuloItensTarefa.Apresentacao;
@{
    Layout = "_Layout";
}
@model E_Agenda.WebApp.Modulos.ModuloTarefa.Apresentacao.EditarTarefaViewModel

<a asp-action="Listar" class="btn btn-outline-secondary rounded-pill px-4 mb-4">
    <i class="bi bi-arrow-left me-1"></i> Voltar
</a>

<div class="container d-flex justify-content-center">
    <div class="card border-0 shadow-sm rounded-4" style="max-width: 620px; width:100%;">
        <div class="card-body p-4">
            <form asp-action="Editar" method="post">
                <input type="hidden" asp-for="Id" />

                <!-- Campos de Tarefa permanecem iguais -->
                <div class="mb-3">
                    <label asp-for="Titulo" class="form-label fw-semibold text-secondary">Título</label>
                    <input asp-for="Titulo" class="form-control rounded-3" />
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="PrioridadeTarefa" class="form-label fw-semibold text-secondary">Prioridade</label>
                        <select asp-for="PrioridadeTarefa" class="form-select rounded-3" asp-items="Html.GetEnumSelectList<PrioridadeTarefa>()"></select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="DataConclusao" class="form-label fw-semibold text-secondary">Data de Conclusão</label>
                        <input asp-for="DataConclusao" class="form-control rounded-3" type="date" />
                    </div>
                </div>

                <!-- Nova seção simplificada de Itens -->
                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <label class="form-label fw-semibold text-secondary mb-0">Itens da Tarefa</label>
                        
                        <!-- BOTÃO QUE LEVA PARA A TELA DE ADICIONAR ITEM -->
                        <a asp-controller="ItensTarefa" asp-action="Cadastrar" asp-route-tarefaId="@Model.Id" 
                           class="btn btn-outline-primary btn-sm rounded-pill px-3">
                            <i class="bi bi-plus-lg me-1"></i> Adicionar Item
                        </a>
                    </div>
                    <div class="alert alert-warning">
                        <strong>DEBUG:</strong> 
                        Itens na Model: @(Model.Itens != null ? Model.Itens.Count : "NULA")
                    </div>
                    <table class="table table-hover border rounded-3">
                        <thead class="table-light">
                            <tr>
                                <th>Título</th>
                                <th>Status</th>
                                <th class="text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Itens ?? new List<ItensDeTarefasViewModel>())
                            {
                                <tr>
                                    <td>@item.Titulo</td>
                                    <td>@(item.StatusConclusao ? "Concluído" : "Pendente")</td>
                                    <td class="text-end">
                                        <a asp-controller="ItensTarefa" asp-action="Editar" 
                                           asp-route-id="@item.Id" asp-route-tarefaId="@Model.Id" 
                                           class="btn btn-sm btn-outline-warning">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-semibold flex-fill">
                        <i class="bi bi-check-lg me-1"></i> Salvar Alterações da Tarefa
                    </button>
                    <a asp-action="Listar" class="btn btn-outline-secondary rounded-pill px-4 fw-semibold">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>