@using E_Agenda.WebApp.Modulos.ModuloTarefa.Apresentacao
@using E_Agenda.WebApp.Modulos.ModuloTarefa.Dominio
@using E_Agenda.WebApp.Modulos.ModuloItensTarefa.Apresentacao;

@{
    Layout = "_Layout";
}
@model E_Agenda.WebApp.Modulos.ModuloTarefa.Apresentacao.CadastrarTarefaViewModel

<a asp-action="Listar" class="btn btn-outline-secondary rounded-pill px-4 mb-4">
    <i class="bi bi-arrow-left me-1"></i> Voltar
</a>

<div class="container d-flex justify-content-center">
    <div class="card border-0 shadow-sm rounded-4" style="max-width: 620px; width:100%;">
        <div class="card-body p-4">
            <form asp-action="Cadastrar" method="post">

                <div class="mb-3">
                    <label asp-for="Titulo" class="form-label fw-semibold text-secondary">Título</label>
                    <input asp-for="Titulo" class="form-control rounded-3" />
                    <span asp-validation-for="Titulo" class="text-danger small"></span>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="PrioridadeTarefa" class="form-label fw-semibold text-secondary">Prioridade</label>
                        <select asp-for="PrioridadeTarefa" class="form-select rounded-3"
                                asp-items="Html.GetEnumSelectList<PrioridadeTarefa>()"></select>
                        <span asp-validation-for="PrioridadeTarefa" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="DataConclusao" class="form-label fw-semibold text-secondary">Data de Conclusão</label>
                        <input asp-for="DataConclusao" class="form-control rounded-3" type="date" />
                        <span asp-validation-for="DataConclusao" class="text-danger small"></span>
                    </div>
                </div>

                <!-- Seção informativa, sem formulários complexos -->
                <div class="mb-4">
                    <div class="alert alert-info border-0 rounded-3 small">
                        <i class="bi bi-info-circle me-1"></i> 
                        Você poderá adicionar os itens da tarefa logo após salvar o cadastro.
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-semibold flex-fill">
                        <i class="bi bi-check-lg me-1"></i> Cadastrar Tarefa
                    </button>
                    <a asp-action="Listar" class="btn btn-outline-secondary rounded-pill px-4 fw-semibold">
                        Cancelar
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>