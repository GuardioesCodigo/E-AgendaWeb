@using E_Agenda.WebApp.Modulos.ModuloDespesas.Apresentacao
@using E_Agenda.WebApp.Modulos.ModuloDespesas.Dominio
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Despesas";
}
@model List<ListarDespesasViewModel>

<a class="btn btn-primary rounded-pill px-4 mb-3" asp-action="Cadastrar">
    <i class="bi bi-plus-lg me-1"></i> Nova Despesa
</a>

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
        <i class="bi bi-exclamation-circle me-2"></i>@mensagemErro
    </div>
}

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        <i class="bi bi-info-circle me-2"></i>Nenhuma despesa cadastrada.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
        @foreach (ListarDespesasViewModel d in Model)
        {
            var (bgPag, corPag, iconePag, labelPag) = d.FormaPagamento switch
            {
                FormaPagamento.AVista  => ("#dcfce7", "#16a34a", "bi-cash",       "À Vista"),
                FormaPagamento.Credito => ("#dbeafe", "#2563eb", "bi-credit-card", "Crédito"),
                FormaPagamento.Debito  => ("#fef9c3", "#ca8a04", "bi-bank",        "Débito"),
                _                      => ("#f1f5f9", "#64748b", "bi-question",    d.FormaPagamento.ToString())
            };

            <div class="col">
                <div class="card h-100 border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">

                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <div class="d-flex align-items-center gap-2">
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                     style="width:40px;height:40px;background:#ede9fe;">
                                    <i class="bi bi-receipt" style="color:#6366f1;"></i>
                                </div>
                                <h5 class="card-title mb-0 fw-bold text-dark">@d.Descricao</h5>
                            </div>
                            <span class="badge rounded-pill fw-semibold"
                                  style="background:#ede9fe;color:#6366f1;font-size:.7rem;">
                                @d.Id.ToString().Substring(0, 8)
                            </span>
                        </div>

                        <div class="mb-3">
                            <span class="fw-bold" style="font-size:1.4rem;color:#dc2626;">
                                @d.Valor.ToString(format: "C2")
                            </span>
                        </div>

                        <dl class="row g-2 mb-3">
                            <dt class="col-5 text-secondary fw-semibold small">Data</dt>
                            <dd class="col-7 mb-0 small">
                                <i class="bi bi-calendar3 me-1 text-muted"></i>
                                @d.DataOcorrencia.ToString(format: "dd/MM/yyyy")
                            </dd>

                            <dt class="col-5 text-secondary fw-semibold small">Pagamento</dt>
                            <dd class="col-7 mb-0">
                                <span class="badge rounded-pill px-2 py-1 fw-semibold small"
                                      style="background:@bgPag;color:@corPag;">
                                    <i class="bi @iconePag me-1"></i>@labelPag
                                </span>
                            </dd>

                            <dt class="col-5 text-secondary fw-semibold small">Categoria</dt>
                            <dd class="col-7 mb-0">
                                <span class="badge rounded-pill px-2 py-1 fw-semibold small"
                                      style="background:#ede9fe;color:#6d28d9;">
                                    <i class="bi bi-tag me-1"></i>@d.CategoriaTitulo
                                </span>
                            </dd>
                        </dl>

                        <div class="d-flex flex-wrap gap-2 mt-auto justify-content-end">
                            <a class="btn btn-sm rounded-pill px-3 fw-semibold"
                               style="background:#ede9fe;color:#6366f1;border:none;"
                               asp-action="Editar" asp-route-id="@d.Id">
                                <i class="bi bi-pencil me-1"></i>Editar
                            </a>
                            <a class="btn btn-sm rounded-pill px-3 fw-semibold"
                               style="background:#fee2e2;color:#dc2626;border:none;"
                               asp-action="Excluir" asp-route-id="@d.Id">
                                <i class="bi bi-trash me-1"></i>Excluir
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
}