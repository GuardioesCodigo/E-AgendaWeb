@using E_Agenda.WebApp.Modulos.ModuloDespesas.Apresentacao
@using E_Agenda.WebApp.Modulos.ModuloDespesas.Dominio
@{
    Layout = "_Layout";
}

@model List<ListarDespesasViewModel>

<a class="btn btn-primary rounded-pill px-4 mb-3" asp-action="Cadastrar">
    <i class="bi bi-plus-lg me-1"></i> Nova Despesa
</a>

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
        <i class="bi bi-exclamation-circle me-2"></i>@mensagemErro
    </div>
}

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        <i class="bi bi-info-circle me-2"></i>Nenhuma despesa cadastrada.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2">
        @foreach (ListarDespesasViewModel d in Model)
        {
            var (bgPag, corPag, iconePag, labelPag) = d.FormaPagamento switch
            {
                FormaPagamento.AVista  => ("#dcfce7", "#16a34a", "bi-cash",        "À Vista"),
                FormaPagamento.Credito => ("#dbeafe", "#2563eb", "bi-credit-card",  "Crédito"),
                FormaPagamento.Debito  => ("#fef9c3", "#ca8a04", "bi-bank",         "Débito"),
                _                      => ("#f1f5f9", "#64748b", "bi-question",     d.FormaPagamento.ToString())
            };

            <div class="col">
                <div class="card h-100">
                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <h5 class="card-title mb-0">@d.Descricao</h5>
                            <span class="badge text-bg-primary rounded-pill">
                                @d.Id.ToString().Substring(0, 8)
                            </span>
                        </div>

                        <dl class="row g-2 mb-4">
                            <dt class="col-5 text-secondary fw-semibold">Valor</dt>
                            <dd class="col-7 mb-0 fw-bold text-danger">@d.Valor.ToString("C2")</dd>

                            <dt class="col-5 text-secondary fw-semibold">Data</dt>
                            <dd class="col-7 mb-0">@d.DataOcorrencia.ToString("dd/MM/yyyy")</dd>

                            <dt class="col-5 text-secondary fw-semibold">Pagamento</dt>
                            <dd class="col-7 mb-0">
                                <span class="badge rounded-pill px-2 py-1 fw-semibold"
                                      style="background:@bgPag;color:@corPag;font-size:.75rem;">
                                    <i class="bi @iconePag me-1"></i>@labelPag
                                </span>
                            </dd>

                            <dt class="col-5 text-secondary fw-semibold">Categoria</dt>
                            <dd class="col-7 mb-0">
                                <span class="badge rounded-pill px-2 py-1 fw-semibold"
                                      style="background:#ede9fe;color:#6d28d9;font-size:.75rem;">
                                    <i class="bi bi-tag me-1"></i>@d.CategoriaTitulo
                                </span>
                            </dd>
                        </dl>

                        <div class="d-flex flex-wrap gap-2 mt-auto justify-content-end">
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3"
                               asp-action="Editar" asp-route-id="@d.Id">Editar</a>
                            <a class="btn btn-outline-danger btn-sm rounded-pill px-3"
                               asp-action="Excluir" asp-route-id="@d.Id">Excluir</a>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
}