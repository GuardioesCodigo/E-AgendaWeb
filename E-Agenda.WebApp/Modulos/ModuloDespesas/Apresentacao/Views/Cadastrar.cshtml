@using E_Agenda.WebApp.Modulos.ModuloDespesas.Apresentacao
@{
    Layout = "_Layout";
}

@model CadastrarDespesaViewModel

<a asp-action="Listar" class="btn btn-outline-secondary rounded-pill px-4 mb-4">
    <i class="bi bi-arrow-left me-1"></i> Voltar
</a>

<div class="container d-flex justify-content-center">
    <div class="card border-0 shadow-sm rounded-4" style="max-width: 620px; width:100%;">
        <div class="card-body p-4">
            <form asp-action="Cadastrar" method="post">

                <div class="mb-3">
                    <label asp-for="Descricao" class="form-label fw-semibold text-secondary">Descrição</label>
                    <input asp-for="Descricao" class="form-control rounded-3"
                           placeholder="Ex: Conta de luz, Supermercado..." />
                    <span asp-validation-for="Descricao" class="text-danger small"></span>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="Valor" class="form-label fw-semibold text-secondary">Valor (R$)</label>
                        <div class="input-group">
                            <span class="input-group-text fw-semibold text-primary bg-light">R$</span>
                            <input asp-for="Valor" class="form-control rounded-end-3"
                                   type="number" step="0.01" min="0.01" placeholder="0,00" />
                        </div>
                        <span asp-validation-for="Valor" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="DataOcorrencia" class="form-label fw-semibold text-secondary">
                            Data de Ocorrência
                            <span class="fw-normal text-muted small">(opcional)</span>
                        </label>
                        <input asp-for="DataOcorrencia" class="form-control rounded-3" type="date" />
                        <span asp-validation-for="DataOcorrencia" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold text-secondary">Forma de Pagamento</label>
                    <div class="row g-2">
                        <div class="col-4">
                            <input type="radio" class="btn-check" asp-for="FormaPagamento"
                                   value="AVista" id="avista" autocomplete="off" />
                            <label class="btn btn-outline-secondary w-100 rounded-3 py-3 d-flex flex-column align-items-center gap-1" for="avista">
                                <i class="bi bi-cash fs-4 text-success"></i>
                                <span class="fw-semibold small">À Vista</span>
                            </label>
                        </div>
                        <div class="col-4">
                            <input type="radio" class="btn-check" asp-for="FormaPagamento"
                                   value="Credito" id="credito" autocomplete="off" />
                            <label class="btn btn-outline-secondary w-100 rounded-3 py-3 d-flex flex-column align-items-center gap-1" for="credito">
                                <i class="bi bi-credit-card fs-4 text-primary"></i>
                                <span class="fw-semibold small">Crédito</span>
                            </label>
                        </div>
                        <div class="col-4">
                            <input type="radio" class="btn-check" asp-for="FormaPagamento"
                                   value="Debito" id="debito" autocomplete="off" />
                            <label class="btn btn-outline-secondary w-100 rounded-3 py-3 d-flex flex-column align-items-center gap-1" for="debito">
                                <i class="bi bi-bank fs-4" style="color:#ca8a04;"></i>
                                <span class="fw-semibold small">Débito</span>
                            </label>
                        </div>
                    </div>
                    <span asp-validation-for="FormaPagamento" class="text-danger small d-block mt-1"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="CategoriaId" class="form-label fw-semibold text-secondary">Categoria</label>
                    <select asp-for="CategoriaId" class="form-select rounded-3"
                            asp-items="@(new SelectList(ViewBag.Categorias, "Id", "Titulo"))">
                        <option value="">Selecione uma categoria...</option>
                    </select>
                    <span asp-validation-for="CategoriaId" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-semibold flex-fill">
                        <i class="bi bi-check-lg me-1"></i> Cadastrar
                    </button>
                    <a asp-action="Listar" class="btn btn-outline-secondary rounded-pill px-4 fw-semibold">
                        Cancelar
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>

