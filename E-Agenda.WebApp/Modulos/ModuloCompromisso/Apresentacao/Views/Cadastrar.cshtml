@using E_Agenda.WebApp.Modulos.ModuloCompromisso.Apresentacao
@using E_Agenda.WebApp.Modulos.ModuloCompromisso.Dominio
@model CadastrarCompromissoViewModel

@{
    ViewData["Title"] = "Cadastrar Compromisso";
    Layout = "_Layout";
}

<div style="max-width:640px;">

    <a asp-action="Listar" class="btn btn-outline-secondary rounded-pill px-4 mb-4">
        <i class="bi bi-arrow-left me-1"></i> Voltar
    </a>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <form asp-action="Cadastrar" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                <div class="mb-3">
                    <label asp-for="Assunto" class="form-label fw-semibold text-secondary">Assunto</label>
                    <input asp-for="Assunto" class="form-control rounded-3" placeholder="Ex: Reunião de Planejamento" />
                    <span asp-validation-for="Assunto" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Data" class="form-label fw-semibold text-secondary">Data</label>
                    <input asp-for="Data" class="form-control rounded-3" type="date" />
                    <span asp-validation-for="Data" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="HoraInicio" class="form-label fw-semibold text-secondary">Início</label>
                        <input asp-for="HoraInicio" class="form-control rounded-3" type="time" />
                        <span asp-validation-for="HoraInicio" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="HoraTermino" class="form-label fw-semibold text-secondary">Término</label>
                        <input asp-for="HoraTermino" class="form-control rounded-3" type="time" />
                        <span asp-validation-for="HoraTermino" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Tipo" class="form-label fw-semibold text-secondary">Tipo</label>
                    <select asp-for="Tipo" class="form-select rounded-3" asp-items="Html.GetEnumSelectList<TipoCompromisso>()">
                        <option value="">Selecione...</option>
                    </select>
                    <span asp-validation-for="Tipo" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Local" class="form-label fw-semibold text-secondary">Local</label>
                    <input asp-for="Local" class="form-control rounded-3" placeholder="Endereço do local" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-outline-primary rounded-pill px-4 fw-semibold flex-fill">
                        <i class="bi bi-check-lg me-1"></i> Cadastrar
                    </button>
                    <a asp-action="Listar" class="btn btn-outline-secondary rounded-pill px-4 fw-semibold">
                        Cancelar
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}