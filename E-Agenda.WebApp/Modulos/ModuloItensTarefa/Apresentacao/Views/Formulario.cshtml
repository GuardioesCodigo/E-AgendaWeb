@model E_Agenda.WebApp.Modulos.ModuloItensTarefa.Apresentacao.ItensDeTarefasViewModel
@{
    ViewBag.Title = Model.Id == Guid.Empty ? "Adicionar Item" : "Editar Item";
    Layout = "_Layout";
}

<div class="container d-flex justify-content-center mt-5">
    <div class="card border-0 shadow-sm rounded-4" style="max-width: 500px; width: 100%;">
        <div class="card-body p-4">
            <h4 class="mb-4 fw-semibold text-secondary">@ViewBag.Title</h4>

            <form asp-action="@(Model.Id == Guid.Empty ? "Cadastrar" : "Editar")" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ItensDeTarefaId" />

                <div class="mb-3">
                    <label asp-for="Titulo" class="form-label fw-semibold text-secondary">Título do Item</label>
                    <input asp-for="Titulo" class="form-control rounded-3" />
                    <span asp-validation-for="Titulo" class="text-danger small"></span>
                </div>

                @if (Model.Id != Guid.Empty)
                {
                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="StatusConclusao" class="form-check-input" role="switch" />
                            <label asp-for="StatusConclusao" class="form-check-label fw-semibold text-secondary">Item concluído</label>
                        </div>
                    </div>
                }

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-semibold flex-fill">
                        <i class="bi bi-check-lg me-1"></i> Salvar
                    </button>
                    <a asp-action="Editar" asp-controller="Tarefa" asp-route-id="@Model.ItensDeTarefaId" 
                       class="btn btn-outline-secondary rounded-pill px-4 fw-semibold">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>