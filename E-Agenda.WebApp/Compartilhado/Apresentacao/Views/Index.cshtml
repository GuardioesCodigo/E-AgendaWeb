@{
    ViewData[index: "Title"] = "Início";
    Layout = "_Layout";

    string[] saudacoes = { "Boa madrugada", "Bom dia", "Boa tarde", "Boa noite" };
    int hora = DateTime.Now.Hour;
    string? saudacao = hora switch
    {
        >= 6 and < 12 => saudacoes[1],
        >= 12 and < 18 => saudacoes[2],
        >= 18 and < 24 => saudacoes[3],
        _ => saudacoes[0] 
    };
}

<section class="hero-inicio">
    <h1 class="hero-titulo">@saudacao</h1>
    <p class="hero-subtitulo">O que você quer organizar hoje?</p>
</section>

<div class="row g-3">

    <div class="col-12 col-sm-6 col-lg-4">
        <a class="card card-modulo modulo-despesas h-100 p-4 text-decoration-none" asp-controller="Despesa" asp-action="Listar">
            <svg class="modulo-icone" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 1v22M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
            </svg>
            <span class="modulo-tag">Financeiro</span>
            <h2 class="modulo-titulo">Despesas</h2>
            <p class="modulo-descricao">Registre e acompanhe seus gastos.</p>
        </a>
    </div>

    <div class="col-12 col-sm-6 col-lg-4">
        <a class="card card-modulo modulo-categorias h-100 p-4 text-decoration-none" asp-controller="Categoria" asp-action="Listar">
            <svg class="modulo-icone" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 7l2-3h4l2 3M3 7h18M3 7v12a1 1 0 001 1h16a1 1 0 001-1V7"/>
            </svg>
            <span class="modulo-tag">Financeiro</span>
            <h2 class="modulo-titulo">Categorias</h2>
            <p class="modulo-descricao">Organize despesas por tipo.</p>
        </a>
    </div>

    <div class="col-12 col-sm-6 col-lg-4">
        <a class="card card-modulo modulo-tarefas h-100 p-4 text-decoration-none" asp-controller="Tarefa" asp-action="Listar">
            <svg class="modulo-icone" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 11l3 3L22 4M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
            </svg>
            <span class="modulo-tag">Produtividade</span>
            <h2 class="modulo-titulo">Tarefas</h2>
            <p class="modulo-descricao">O que precisa ser feito.</p>
        </a>
    </div>

    <div class="col-12 col-sm-6 col-lg-4">
        <a class="card card-modulo modulo-contatos h-100 p-4 text-decoration-none" asp-controller="Contatos" asp-action="Listar">
            <svg class="modulo-icone" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
            </svg>
            <span class="modulo-tag">Pessoas</span>
            <h2 class="modulo-titulo">Contatos</h2>
            <p class="modulo-descricao">Quem está na sua agenda.</p>
        </a>
    </div>

    <div class="col-12 col-sm-6 col-lg-4">
        <a class="card card-modulo modulo-compromissos h-100 p-4 text-decoration-none" asp-controller="Compromisso" asp-action="Listar">
            <svg class="modulo-icone" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2"/>
                <path d="M16 2v4M8 2v4M3 10h18"/>
            </svg>
            <span class="modulo-tag">Agenda</span>
            <h2 class="modulo-titulo">Compromissos</h2>
            <p class="modulo-descricao">Seus próximos eventos.</p>
        </a>
    </div>

</div>